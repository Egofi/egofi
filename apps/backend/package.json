{
  "name": "@egofi/backend",
  "version": "0.0.1",
  "private": true,
  "description": "Egofi NestJS API, settlement engine, and webhook ingest",
  "main": "dist/main.js",
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start:api": "node dist/main.js",
    "start:worker": "ROLE=worker node dist/main.js",
    "start:webhook": "ROLE=webhook node dist/main.js",
    "lint": "biome check src/ && eslint .",
    "lint:promises": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "db:seed:merchant": "node --env-file=.env prisma/seed-merchant.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:grant": "docker exec -i egofi-dev-postgres-1 psql -U egofi -d egofi -v password=egofi_app_dev -f - < prisma/grant-app-role.sql",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bull-board/api": "^5.23.0",
    "@bull-board/fastify": "^5.23.0",
    "@bull-board/nestjs": "^5.23.0",
    "@egofi/types": "workspace:*",
    "@fastify/multipart": "^8.3.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.3.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@prisma/client": "^6.2.1",
    "@scure/base": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.5.1",
    "crypto": "^1.0.1",
    "decimal.js": "^10.5.0",
    "fastify": "^4.29.0",
    "ioredis": "^5.4.2",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@egofi/config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@scure/bip39": "^2.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.18.0",
    "prisma": "^6.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
