# App
NODE_ENV=development
PORT=3000
ROLE=api

# Database
DATABASE_URL=postgresql://egofi:egofi_dev@localhost:5432/egofi

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-32-chars-minimum
JWT_EXPIRES_IN=7d

# Tatum
TATUM_API_KEY=your-tatum-api-key
TATUM_WEBHOOK_HMAC_SECRET=your-tatum-hmac-secret

# ChangeNOW (primary swap)
CHANGENOW_API_KEY=your-changenow-api-key

# SimpleSwap (fallback swap)
SIMPLESWAP_API_KEY=your-simpleswap-api-key

# Merchant webhooks
WEBHOOK_SIGNING_SECRET=change-me-in-production

# Cloudinary (KYB document storage — private/authenticated uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Sentry
SENTRY_DSN=

# Admin JWT (separate secret for admin sessions)
ADMIN_JWT_SECRET=change-me-in-production-admin-secret

# App base URL (used to build public URLs)
APP_BASE_URL=http://localhost:3000
CHECKOUT_BASE_URL=http://localhost:3001
