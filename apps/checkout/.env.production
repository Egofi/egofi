NEXT_PUBLIC_API_MODE=production
# Set NEXT_PUBLIC_API_URL to your deployed backend URL at build time
# e.g. NEXT_PUBLIC_API_URL=https://api.egofi.io
# Public origin of this app. Makes the og:image on share cards absolute;
# without it Next falls back to localhost. e.g. NEXT_PUBLIC_SITE_URL=https://pay.egofi.io
# NEXT_PUBLIC_SITE_URL=
