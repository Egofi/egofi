{
  "name": "egofi",
  "private": true,
  "version": "0.0.1",
  "description": "Non-custodial crypto payment gateway for African merchants",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:all": "pnpm --recursive --parallel --stream run dev",
    "test:all": "pnpm --recursive --stream run test",
    "typecheck:all": "pnpm --recursive --stream run typecheck",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": ["biome check --write --no-errors-on-unmatched"]
  },
  "packageManager": "pnpm@9.15.4"
}
